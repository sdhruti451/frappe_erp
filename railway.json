{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "images/production/Dockerfile"
  },
  "deploy": {
    "startCommand": "docker compose -f pwd.yml up -d",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
